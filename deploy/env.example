# Copy to /etc/donto-memory/env and chmod 600.
# All settings are also documented in donto_memory/config.py.

# --- substrate binding (REQUIRED) ---
DONTO_MEMORY_DONTOSRV_URL=http://localhost:7879
DONTO_MEMORY_DONTO_DSN=postgres://donto:CHANGEME@127.0.0.1:5432/donto

# --- consumer identity ---
DONTO_MEMORY_CONSUMER_IRI=ctx:memory
DONTO_MEMORY_DEFAULT_HOLDER=agent:anonymous

# --- API server ---
DONTO_MEMORY_API_BIND=127.0.0.1:7900
DONTO_MEMORY_API_CORS_ORIGINS=["*"]

# --- hot path ---
DONTO_MEMORY_RECALL_DEFAULT_LIMIT=50
DONTO_MEMORY_RECALL_MAX_LIMIT=500
DONTO_MEMORY_ENABLE_RECONSOLIDATION_ENQUEUE=true

# --- sleep path ---
DONTO_MEMORY_WORKER_POLL_INTERVAL_SECONDS=5.0
DONTO_MEMORY_WORKER_BATCH_SIZE=8
DONTO_MEMORY_RECONSOLIDATION_COALESCE_WINDOW_SECONDS=300

# --- optional LLM reflection (sleep path) ---
# DONTO_MEMORY_LLM_BASE_URL=https://openrouter.ai/api/v1
# DONTO_MEMORY_LLM_API_KEY=sk-...
# DONTO_MEMORY_LLM_MODEL=z-ai/glm-5
